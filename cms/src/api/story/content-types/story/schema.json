{
  "kind": "collectionType",
  "collectionName": "stories",
  "info": {
    "singularName": "story",
    "pluralName": "stories",
    "displayName": "新闻动态",
    "description": "新闻动态和公告"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 255
    },
    "summary": {
      "type": "text"
    },
    "content": {
      "type": "richtext"
    },
    "category": {
      "type": "enumeration",
      "enum": ["news", "notice"],
      "default": "news"
    },
    "source": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "isPublished": {
      "type": "boolean",
      "default": false
    }
  }
}